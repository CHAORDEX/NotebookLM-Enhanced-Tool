{
   "action": {
      "default_icon": {
         "128": "assets/icons/icon128.png",
         "16": "assets/icons/icon16.png",
         "48": "assets/icons/icon48.png"
      },
      "default_popup": ""
   },
   "author": "NotebookLM Tool",
   "background": {
      "service_worker": "background/service-worker.js"
   },
   "content_scripts": [
      {
         "js": [
            "content/content-script.js"
         ],
         "matches": [
            "https://notebooklm.google.com/*"
         ],
         "run_at": "document_start"
      }
   ],
   "web_accessible_resources": [
      {
         "resources": [
            "content/inject.js"
         ],
         "matches": [
            "https://notebooklm.google.com/*"
         ]
      }
   ],
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com;"
   },
   "description": "NotebookLM mindmap copy and download tool",
   "host_permissions": [
      "https://notebooklm.google.com/*",
      "https://lh3.googleusercontent.com/*",
      "https://lh3.google.com/*"
   ],
   "icons": {
      "128": "assets/icons/icon128.png",
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "NotebookLM Mindmap Tool",
   "permissions": [
      "notifications",
      "activeTab",
      "downloads"
   ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.16"
}